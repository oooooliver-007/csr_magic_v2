# CSR Magic 后端 — 环境变量参考
#
# ┌─────────────────────────────────────────────────────────────┐
# │ 本地开发                                                     │
# │  运行 set-env.bat（CMD）或 .\set-env.ps1（PowerShell）       │
# │  → 自动激活 dev profile，加载 application-dev.yml            │
# │  → 无需额外设置任何环境变量                                   │
# └─────────────────────────────────────────────────────────────┘
#
# ┌─────────────────────────────────────────────────────────────┐
# │ 生产环境                                                     │
# │  必须设置以下环境变量，application.yml 无默认值会拒绝启动      │
# └─────────────────────────────────────────────────────────────┘

# 数据库密码（必填，application.yml 无默认值）
DATABASE_PASSWORD=your_production_db_password

# JWT 签名密钥（必填，至少 256 位随机值）
# 生成：python -c "import secrets,base64; print(base64.urlsafe_b64encode(secrets.token_bytes(32)).decode())"
JWT_SECRET=your_production_jwt_secret

# ======== 以下变量有默认值，可按需覆盖 ========

# 数据库连接（默认: jdbc:postgresql://localhost:5432/CSR_DB?currentSchema=csr_v2）
# DATABASE_URL=jdbc:postgresql://your-host:5432/CSR_DB?currentSchema=csr_v2
# DATABASE_USERNAME=postgres

# AI 服务地址（默认: http://localhost:8000）
# AI_SERVICE_URL=http://ai-service:8000

# AI 服务 API 令牌（需与 AI 服务 API_AUTH_TOKEN 一致）
# AI_SERVICE_API_TOKEN=your_shared_token

# AI 服务回调令牌（需与 AI 服务 POSTER_CALLBACK_TOKEN 一致）
# POSTER_CALLBACK_TOKEN=your_callback_token

# CORS 允许来源（默认: http://localhost:3000）
# CORS_ALLOWED_ORIGINS=https://your-frontend.com

# HTTPS 环境需开启
# COOKIE_SECURE=true