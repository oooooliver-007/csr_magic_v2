# 后端所需环境变量（请创建 .env 文件或直接设置系统环境变量）

# JWT 签名密钥（必须为至少 256 位随机值）
# 生成方式：python -c "import secrets,base64; print(base64.urlsafe_b64encode(secrets.token_bytes(32)).decode())"
JWT_SECRET=your_generated_key_here

# 数据库密码
DATABASE_PASSWORD=your_db_password_here

# 数据库连接（有默认值，可不设）
# DATABASE_URL=jdbc:postgresql://localhost:5432/CSR_DB?currentSchema=csr_v2
# DATABASE_USERNAME=postgres

# AI 服务地址（有默认值，可不设）
# AI_SERVICE_URL=http://localhost:8000
