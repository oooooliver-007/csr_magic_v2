# =============================================================================
# CSR Magic — 生产环境变量清单
# 部署前必须逐项检查，不设置必填项会导致服务拒绝启动
# =============================================================================

# =============================================================================
# 一、csr_magic_backend（Spring Boot，端口 8080）
# =============================================================================

# --- 必填 ---

# 数据库密码
DATABASE_PASSWORD=

# JWT 签名密钥（至少 256 位随机值，生成命令见下方）
JWT_SECRET=


# --- 推荐设置 ---

# 数据库连接（默认: jdbc:postgresql://localhost:5432/CSR_DB?currentSchema=csr_v2）
DATABASE_URL=jdbc:postgresql://<生产DB地址>:5432/CSR_DB?currentSchema=csr_v2
DATABASE_USERNAME=postgres

# AI 服务地址
AI_SERVICE_URL=http://<AI服务地址>:8000

# AI 服务 API 令牌（需与 AI 服务 API_AUTH_TOKEN 一致）
AI_SERVICE_API_TOKEN=

# AI 服务回调令牌（需与 AI 服务 POSTER_CALLBACK_TOKEN 一致）
POSTER_CALLBACK_TOKEN=

# CORS 允许的前端来源（逗号分隔，默认: http://localhost:3000）
CORS_ALLOWED_ORIGINS=https://<前端域名>

# HTTPS 环境下开启 Cookie Secure 标志
COOKIE_SECURE=true


# --- 可选 ---

# 服务端口（默认: 8080）
# SERVER_PORT=8080

# JWT 过期时间（默认: access 1h, refresh 7d，单位毫秒）
# JWT_ACCESS_EXPIRATION=3600000
# JWT_REFRESH_EXPIRATION=604800000

# 日志级别（默认: INFO, WARN）
# LOG_LEVEL_CSR=INFO
# LOG_LEVEL_SECURITY=WARN


# =============================================================================
# 二、csr_ai_service（Python FastAPI，端口 8000）
# =============================================================================

# --- 必填 ---

# 阿里云 DashScope API Key（通义万相图片生成）
DASHSCOPE_API_KEY=


# --- 推荐设置 ---

# API 鉴权令牌（需与后端 AI_SERVICE_API_TOKEN 一致）
API_AUTH_TOKEN=

# 后端回调令牌（需与后端 POSTER_CALLBACK_TOKEN 一致）
POSTER_CALLBACK_TOKEN=

# 后端回调地址
BACKEND_BASE_URL=http://<后端地址>:8080

# CORS 允许来源（逗号分隔，默认: http://localhost:3000,http://localhost:8080）
CORS_ORIGINS=https://<前端域名>,http://<后端地址>:8080


# --- 可选 ---

# 服务端口（默认: 8000）
# PORT=8000

# 图像生成模型（默认: wan2.7-image-pro）
# IMAGE_MODEL=wan2.7-image-pro

# 海报存储目录（默认: static/posters）
# POSTER_STORAGE_DIR=static/posters


# =============================================================================
# 三、csr_magic_frontend（React/Vite，端口 3000）
# =============================================================================

# --- 推荐设置 ---

# 后端 API 地址（默认: http://localhost:8080）
VITE_API_BASE_URL=https://<后端域名>


# =============================================================================
# JWT 密钥生成命令（PowerShell / Linux）
# python -c "import secrets,base64; print(base64.urlsafe_b64encode(secrets.token_bytes(32)).decode())"
# =============================================================================
