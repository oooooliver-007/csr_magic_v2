# DashScope API Key（必需）
# 从阿里云 DashScope 控制台获取: https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=sk-your-dashscope-api-key-here

# 图像生成模型（可选，默认 wan2.7-image-pro）
IMAGE_MODEL=wan2.7-image-pro

# 服务端口（可选，默认 8000）
PORT=8000

# 海报存储目录（可选）
POSTER_STORAGE_DIR=static/posters

# 后端回调 URL（可选，默认 http://localhost:8080）
BACKEND_BASE_URL=http://localhost:8080

# 回调认证令牌（与后端 POSTER_CALLBACK_TOKEN 一致，用于服务间认证）
POSTER_CALLBACK_TOKEN=
